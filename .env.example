# =============================================================================
# Chef & Serve — env example. Copy to .env.local for local dev.
# Production values live in Vercel project Settings → Environment Variables.
# =============================================================================

# ----- App URLs -----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Auth.js (PR-0E) -----
# Generate via: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# ----- Neon Postgres (PR-0D) -----
# Pooled connection — for the running app (uses Neon's PgBouncer)
DATABASE_URL=
# Unpooled — for drizzle-kit migrate (no pooler hop, long-lived connection)
# Same string as DATABASE_URL with `-pooler` removed from the host.
DATABASE_URL_UNPOOLED=

# ----- Resend (PR-0E) -----
RESEND_API_KEY=
RESEND_FROM_EMAIL=info@jezzacooks.com

# ----- Seed users (PR-0D) -----
# Placeholders. Real Maarten/Gina emails to be set later via UPDATE.
JEZZA_EMAIL=info@jezzacooks.com
MAARTEN_EMAIL=maarten@jezzacooks.com
GINA_EMAIL=gina@jezzacooks.com

# ----- Cloudflare R2 (Phase 2 polish — file uploads) -----
# All optional until R2 is wired up
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=chefandserve-docs
R2_ENDPOINT=
R2_PUBLIC_URL=

# ----- Encryption keys (AES-256-GCM secrets at rest) -----
# Generate each via: openssl rand -base64 32
# TOTP_ENCRYPTION_KEY  — encrypts users.totp_secret_encrypted (2FA).
# PII_ENCRYPTION_KEY   — encrypts chefs.bsn/iban/id_number (onboarding PII, PR-FB-0).
TOTP_ENCRYPTION_KEY=
PII_ENCRYPTION_KEY=

# ----- Phase 9 (AI matching — defer until you have data) -----
OPENAI_API_KEY=

# ----- Optional analytics (marketing only) -----
NEXT_PUBLIC_GA_ID=G-MYV713V86X
NEXT_PUBLIC_GTM_ID=GT-TBWHRP76
GOOGLE_SITE_VERIFICATION=
